{
	"log": {
		"level": "info",
		"file": "log.txt"
	},
	"servers": [
		{
			"id": "cloudflare",
			"protocol": "h2",
			"remote_addrs": ["1.1.1.1:443", "1.0.0.1:443", "104.16.248.249:443", "104.16.249.249:443"],
			"hostname": "cloudflare-dns.com",
			"path": "/dns-query",
			"http_method": "GET",
			"sni": "cloudflare-dns.com",
			"ip_as_sni": false,
			"disable_certificate_validation": false
		}
	],
	"serve_addrs": "127.0.0.1:53",
	"interface": null,
	"response_timeout": 2,
	"connection_keep_alive": 10,
	"reconnect_sleep": 1,
	"pipe_capacity": 12,
	"tls_core": "rustls",
	"fragmenting": {
		"enable": false,
		"method": "single",
		"sleep_interval": "10-100",
		"fragment_size": "50-100",
		"segments": 2
	},
	"noiser": {
		"enable": false,
		"noises": [
			{
				"ntype": "dht",
				"content": "",
				"size": "1-100",
				"sleep": 10
			},
			{
				"ntype": "tracker",
				"content": "",
				"size": "1-100",
				"sleep": 10
			}
		]
	},
	"quic": {
		"congestion_controller": "bbr",
		"keep_alive_interval": null,
		"connecting_timeout": 2,
		"datagram_receive_buffer_size": 1048576,
		"datagram_send_buffer_size": 1048576,
		"packet_threshold": 12,
		"initial_mtu": null,
		"min_mtu": null,
		"crypto_buffer_size": 1048576,
		"stream_receive_window": 8192,
		"max_idle_timeout": 300
	},
	"h2": {
		"header_table_size": 4096,
		"max_header_list_size": 16384,
		"initial_connection_window_size": 1048576,
		"initial_window_size": 8192,
		"max_pending_accept_reset_streams": 20,
		"max_concurrent_reset_streams": 50,
		"max_frame_size": 16777214
	},
	"tcp_socket_options": {
		"send_buffer_size": null,
		"recv_buffer_size": null,
		"nodelay": null,
		"keepalive": null
	},
	"doh_server": {
		"enable": false,
		"alpn": ["h2", "http/1.1"],
		"listen_address": "127.0.0.1:443",
		"certificate": "cert.crt",
		"key": "key.pem",
		"cache_control": "max-age=3600",
		"response_timeout": 3,
		"log_errors": false
	},
	"runtime": {
		"runtime_mode": "Multi",
		"worker_threads": null,
		"thread_stack_size": null,
		"event_interval": 30,
		"global_queue_interval": 15,
		"max_io_events_per_tick": null,
		"thread_keep_alive": null
	},
	"rules": [
		{
			"options": [
				"doubleclick.net",
				"google-analytics.com",
				"googlesyndication.com",
				"firebaseinstallations.googleapis.com",
				"www.googletagservices.com"
			],
			"target": {
				"block": null
			}
		}
	],
	"overwrite": null
}